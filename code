            background: linear-gradient(90deg, #9f4bff, #c084fc);
            color: white;
            padding: 16px 50px;
            font-size: 1.3rem;
            font-weight: 600;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.4s;
            box-shadow: 0 10px 35px rgba(159,75,255,0.4);
        }
        .btn:hover { transform: scale(1.08); box-shadow: 0 15px 45px rgba(159,75,255,0.6); }

